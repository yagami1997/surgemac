# > hulo.list - CN Social Routing Rules
# > Domain-based routing for network optimization

# ========================================
# CN Social Platform A - 知乎 (Zhihu)
# ========================================

# > User-Agent Rules
USER-AGENT,*zhihu*
USER-AGENT,*ZhihuHybrid*

# > Domain Rules
DOMAIN-SUFFIX,zhihu.com
DOMAIN-SUFFIX,zhimg.com
DOMAIN-KEYWORD,zhihu

# ========================================
# CN Social Platform B - 小红书 (XHS)
# ========================================

# > User-Agent Rules
USER-AGENT,*xiaohongshu*

# > Core & CDN Domains (主站与静态资源)
DOMAIN-SUFFIX,xiaohongshu.com
DOMAIN-SUFFIX,xiaohongshu.com.cn
DOMAIN-SUFFIX,xhs.com
DOMAIN-SUFFIX,xhscdn.com
DOMAIN-SUFFIX,xhscdn.net
DOMAIN-SUFFIX,xhsredcdn.com
DOMAIN-SUFFIX,cdnxhs.com

# > Links & Sharing (分享与短链)
DOMAIN-SUFFIX,xhslink.com
DOMAIN-SUFFIX,xhsurl.com

# > Infrastructure (DNS 与 系统服务)
DOMAIN-SUFFIX,xhsdns.com
DOMAIN-SUFFIX,xhsdns.net
DOMAIN-SUFFIX,xhssys.com
DOMAIN,dns.xiaohongshu.com

# > Security & Risk Control (风控与反欺诈)
DOMAIN-SUFFIX,fengkongcloud.com
DOMAIN-SUFFIX,fengkongcloud.net

# > Domain Keywords (仅保留高精准项)
DOMAIN-KEYWORD,xiaohongshu
