# ============================================
# Messenger - Global IM & Chat Applications
# ============================================
# Strategy Group: Messenger
# Purpose: Route all instant messaging and chat app traffic
# Coverage: Discord (+ hCaptcha verification), Telegram, WhatsApp, Signal,
#           Line, Slack, Element/Matrix, Viber, Zalo, Keybase, Mattermost,
#           Session, Threema, Wire, Rocket.Chat
# Node Requirement: Stable JP (recommended: Flower JP Premium2)
# Note: Supersedes discord.list and ruleset/Telegram.list
# ============================================

# ========================================
# Discord
# ========================================

USER-AGENT,*Discord*
USER-AGENT,Discord*

# Core domains (precise match, higher priority than KEYWORD)
DOMAIN,discord.com
DOMAIN,discordapp.com
DOMAIN,discordapp.net
DOMAIN,discord.gg
DOMAIN-SUFFIX,discord.com
DOMAIN-SUFFIX,discordapp.com
DOMAIN-SUFFIX,discordapp.net
DOMAIN-SUFFIX,discord.gg
DOMAIN-SUFFIX,discord.media
DOMAIN-SUFFIX,dis.gd
DOMAIN-SUFFIX,discordstatus.com

# Discord API & Gateway (WebSocket real-time connection)
DOMAIN,api.discord.com
DOMAIN,api.discordapp.com
DOMAIN,gateway.discord.gg
DOMAIN,gateway.discordapp.com

# Discord CDN (images, attachments, external image proxy)
DOMAIN,cdn.discordapp.com
DOMAIN,media.discordapp.net
DOMAIN,media.discord.com
DOMAIN,attachments.discordapp.net
DOMAIN,cdn.discord.com
DOMAIN,images-ext-1.discordapp.net
DOMAIN,images-ext-2.discordapp.net

# Discord updates & client builds (stable / PTB / canary)
DOMAIN,dl.discordapp.net
DOMAIN,updates.discord.com
DOMAIN,ptb.discord.com
DOMAIN,ptb.discordapp.com
DOMAIN,canary.discord.com
DOMAIN,canary.discordapp.com

# Discord misc endpoints
DOMAIN,status.discord.com
DOMAIN,latency.discord.com
DOMAIN,support.discord.com
DOMAIN,store.discord.com
DOMAIN,click.discord.com

DOMAIN-KEYWORD,discord

# ---- Human Verification (hCaptcha) ----
# Discord uses hCaptcha for server join verification.
# Without these rules, the captcha IP differs from the Discord request IP,
# triggering risk control and making verification impossible.
DOMAIN-SUFFIX,hcaptcha.com
DOMAIN-SUFFIX,hmt.ai

# Discord voice server IP ranges
IP-CIDR,66.22.196.0/22,no-resolve
IP-CIDR,66.22.200.0/21,no-resolve
IP-CIDR,66.22.208.0/20,no-resolve
IP-CIDR,66.22.224.0/20,no-resolve
IP-CIDR,66.22.240.0/21,no-resolve
IP-CIDR,66.22.248.0/22,no-resolve

# Discord infrastructure (Google Cloud)
IP-CIDR,35.214.0.0/16,no-resolve
IP-CIDR,35.215.0.0/16,no-resolve

